{
  "name": "realistic-typewriter",
  "version": "0.3.0",
  "description": "A library for generating realistic typing event streams",
  "keywords": [
    "realistic-typewriter",
    "typewriter",
    "typing"
  ],
  "homepage": "https://github.com/fardjad/realistic-typewriter",
  "bugs": {
    "url": "https://github.com/fardjad/realistic-typewriter/issues"
  },
  "contributors": [
    {
      "name": "Fardjad Davari",
      "email": "public@fardjad.com"
    }
  ],
  "author": "Fardjad Davari <public@fardjad.com>",
  "type": "module",
  "exports": {
    ".": {
      "require": {
        "default": "./dist/index.cjs",
        "types": "./dist/index.d.cts"
      },
      "import": {
        "default": "./dist/index.js",
        "types": "./dist/index.d.ts"
      }
    },
    "./layouts": {
      "require": {
        "default": "./dist/layouts/index.cjs",
        "types": "./dist/layouts/index.d.cts"
      },
      "import": {
        "default": "./dist/layouts/index.js",
        "types": "./dist/layouts/index.d.ts"
      }
    }
  },
  "main": "dist/index.cjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist/index.cjs",
    "dist/index.d.cts",
    "dist/index.d.ts",
    "dist/index.js",
    "dist/layouts/index.cjs",
    "dist/layouts/index.d.cts",
    "dist/layouts/index.d.ts",
    "dist/layouts/index.js"
  ],
  "scripts": {
    "build": "bun run clean && bun run build:esm && bun run build:cjs && bun run build:types",
    "build:cjs": "bun build ./src/index.ts ./src/layouts/index.ts --format cjs --target node --packages external --outdir ./dist --entry-naming [dir]/[name].cjs --sourcemap=inline",
    "build:esm": "bun build ./src/index.ts ./src/layouts/index.ts --format esm --target node --packages external --outdir ./dist --entry-naming [dir]/[name].js --sourcemap=inline",
    "build:types": "tsc -p tsconfig.build.json && cp ./dist/index.d.ts ./dist/index.d.cts && cp ./dist/layouts/index.d.ts ./dist/layouts/index.d.cts",
    "clean": "rm -rf dist coverage",
    "fix": "bun x biome check --write .",
    "format": "bun x biome format --write .",
    "lint": "bun x biome check .",
    "prepack": "bun run build",
    "test": "bun run typecheck && bun run test:unit && bun run lint",
    "test:unit": "bun test",
    "typecheck": "tsc -p tsconfig.json",
    "update:deps": "bun update --latest && bun run fix"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fardjad/realistic-typewriter"
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "^2.0.6",
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  },
  "bundledDependencies": [],
  "license": "MIT",
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=20"
  }
}
