{
  "compilerOptions": {
    "lib": ["ESNext"],
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strictNullChecks": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["bun-types", "node"]
  },
  "include": ["src/**/*.ts", "test/**/*.ts"]
}
